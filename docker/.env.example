# Tribu Environment Variables
# Copy to .env and fill in values:  cp .env.example .env

# ── Required ──────────────────────────────────────────────────

# Generate with: openssl rand -hex 32
JWT_SECRET=

# Database password for PostgreSQL
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# ── Optional ──────────────────────────────────────────────────

# Set to true when running behind a TLS reverse proxy (nginx, Caddy, Traefik)
# This enables the Secure flag on auth cookies (HTTPS only)
SECURE_COOKIES=false

# Public URL of your instance (e.g. https://tribu.example.com)
# Auto-detected from request headers if not set
# BASE_URL=

# How long JWT tokens stay valid, in hours (default: 24)
# JWT_EXPIRE_HOURS=24

# ── Push Notifications (optional) ────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys

# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CLAIMS_EMAIL=mailto:admin@example.com
